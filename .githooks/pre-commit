#!/usr/bin/env bash
set -euo pipefail

red() { printf "\033[31m%s\033[0m\n" "$*"; }
green() { printf "\033[32m%s\033[0m\n" "$*"; }

require_file() {
  [[ -f "$1" ]] || { red "Missing required file: $1"; exit 1; }
}

semver_re='^[0-9]+\.[0-9]+\.[0-9]+$'

py_ver() {
  awk 'BEGIN{p=0} /^\[project\]/{p=1;next} /^\[/{p=0} p==1 && $1=="version"{gsub(/"/,"",$3); print $3; exit}' pyproject.toml
}

require_file pyproject.toml
require_file src/whisper_app/__init__.py

PY=$(py_ver)
INIT_VER=$(sed -n -E 's/^__version__\s*=\s*"([0-9]+\.[0-9]+\.[0-9]+)".*/\1/p' src/whisper_app/__init__.py | head -n1)

[[ $PY =~ $semver_re ]] || { red "pyproject.toml version not SemVer: '$PY'"; exit 1; }
[[ $INIT_VER =~ $semver_re ]] || { red "__init__.py version not SemVer: '$INIT_VER'"; exit 1; }

if [[ "$PY" != "$INIT_VER" ]]; then
  red "Version mismatch: pyproject.toml=$PY  __init__.py=$INIT_VER"
  red "Keep versions in sync before committing."
  exit 1
fi

# If source changed, check version bump vs HEAD
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  CHANGED=$(git diff --cached --name-only)

  greater() { python3 - "$1" "$2" <<'PY'
import sys
def norm(v):
    return tuple(map(int, v.split('.'))) if v else None
v1, v2 = map(norm, sys.argv[1:3])
sys.exit(0 if v2 is None or (v1 and v2 and v1>=v2) else 1)
PY
  }

  BASE_PY=$(git show HEAD:pyproject.toml 2>/dev/null | awk 'BEGIN{p=0} /^\[project\]/{p=1;next} /^\[/{p=0} p==1 && $1=="version"{gsub(/"/,"",$3); print $3; exit}')

  if ! greater "$PY" "$BASE_PY"; then
    red "Version went backwards: head=$PY base=${BASE_PY:-unset}"
    exit 1
  fi
fi

green "pre-commit: version check passed (v$PY)"

# ── Sensitive content / credential scan ──
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -n "$STAGED_FILES" ]]; then
  # Forbidden file patterns
  FORBIDDEN_FILES=$(echo "$STAGED_FILES" | grep -iE \
    '\.(env|pem|key|p12|pfx|jks|keystore|pickle|sqlite|db)$|credentials\.json|token\.json|\.secret|id_rsa|id_ed25519' || true)
  if [[ -n "$FORBIDDEN_FILES" ]]; then
    red "pre-commit: potentially sensitive files staged:"
    echo "$FORBIDDEN_FILES" | while read -r f; do red "  $f"; done
    red "Remove them with: git reset HEAD <file>"
    exit 1
  fi

  # Unwanted binary / generated files
  UNWANTED_FILES=$(echo "$STAGED_FILES" | grep -iE \
    '\.(pyc|pyo|so|dylib|dll|exe|whl|egg|coverage|pymon)$|__pycache__|\.egg-info|htmlcov/|\.tox/' || true)
  if [[ -n "$UNWANTED_FILES" ]]; then
    red "pre-commit: generated/binary files should not be committed:"
    echo "$UNWANTED_FILES" | while read -r f; do red "  $f"; done
    red "Add them to .gitignore and unstage with: git reset HEAD <file>"
    exit 1
  fi

  # Scan staged diffs for secret patterns
  SECRET_PATTERNS='(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|AKIA[0-9A-Z]{16}|xox[bpsa]-[a-zA-Z0-9-]{10,}|-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY)'
  SECRETS_FOUND=$(git diff --cached -U0 --diff-filter=ACM | grep -E "^\+" | grep -v "^+++" | grep -oE "$SECRET_PATTERNS" || true)
  if [[ -n "$SECRETS_FOUND" ]]; then
    red "pre-commit: possible secrets/API keys detected in staged changes:"
    echo "$SECRETS_FOUND" | head -5 | while read -r s; do red "  ${s:0:20}..."; done
    red "Remove the secret and consider rotating it."
    exit 1
  fi

  # Check for hardcoded home directory paths (privacy leak)
  HOMEDIR_LEAKS=$(git diff --cached -U0 --diff-filter=ACM | grep -E "^\+" | grep -v "^+++" | grep -oE '/home/[a-zA-Z0-9_]+/' | sort -u || true)
  if [[ -n "$HOMEDIR_LEAKS" ]]; then
    # Allow in files that legitimately reference paths (service templates, setup scripts)
    ALLOWED_FILES='\.service$|setup.*\.sh$|install\.sh$'
    NON_ALLOWED=$(git diff --cached --name-only --diff-filter=ACM | grep -vE "$ALLOWED_FILES" || true)
    if [[ -n "$NON_ALLOWED" ]]; then
      LEAKS_IN_CODE=$(git diff --cached -U0 --diff-filter=ACM -- $NON_ALLOWED | grep -E "^\+" | grep -v "^+++" | grep -oE '/home/[a-zA-Z0-9_]+/' | sort -u || true)
      if [[ -n "$LEAKS_IN_CODE" ]]; then
        red "pre-commit: hardcoded home directory paths found in staged changes:"
        echo "$LEAKS_IN_CODE" | while read -r p; do red "  $p"; done
        red "Use Path.home(), \$HOME, or ~ instead of absolute home paths."
        exit 1
      fi
    fi
  fi

  green "pre-commit: sensitive content scan passed"
fi

# Python linting — critical errors only
if echo "$CHANGED" | grep -E '\.py$' >/dev/null 2>&1; then
  green "pre-commit: running Python linter (critical errors only)"
  if command -v python3 >/dev/null 2>&1; then
    if ! python3 -m flake8 src/whisper_app/ --exclude='*/venv/*,*/.venv/*' --select=E9,F63,F7,F82,F821 --count 2>/dev/null; then
      red "Python linting failed with critical errors. Fix undefined names and syntax errors."
      exit 1
    fi
  fi
fi

# Run tests if source or test files changed
if echo "$CHANGED" | grep -E '^(src/|tests/)' >/dev/null 2>&1; then
  green "pre-commit: running tests (source files changed)"
  if command -v python3 >/dev/null 2>&1; then
    if ! python3 -m pytest tests/ -x -q --timeout=30 --no-header 2>/dev/null; then
      red "Tests failed. Fix failing tests before committing."
      exit 1
    fi
  fi
fi

green "pre-commit: all checks passed"
