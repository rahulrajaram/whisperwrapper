#!/usr/bin/env python3
"""
Whisper Recording Control CLI

Allows external programs (like KDE shortcuts) to control the Whisper GUI
via a named pipe (FIFO). This script sends commands to the running Whisper GUI process.

Usage:
    whisper-recording-toggle start        # Start recording
    whisper-recording-toggle stop         # Stop recording
    whisper-recording-toggle toggle       # Toggle recording
    whisper-recording-toggle status       # Check if GUI is running
"""

import sys
import os
from pathlib import Path


def get_gui_pid():
    """Get the PID of the running Whisper GUI"""
    lock_file = Path.home() / ".whisper" / "app.lock"
    if lock_file.exists():
        try:
            with open(lock_file, 'r') as f:
                pid_str = f.read().strip()
                if pid_str and pid_str.isdigit():
                    pid = int(pid_str)
                    # Verify process still exists
                    try:
                        os.kill(pid, 0)
                        return pid
                    except (OSError, ProcessLookupError):
                        pass
        except Exception as e:
            print(f"❌ Error reading lock file: {e}", file=sys.stderr)
    return None


def send_command(action):
    """Send command to GUI process via named pipe"""
    fifo_path = Path.home() / ".whisper" / "control.fifo"

    try:
        # Open FIFO for writing (non-blocking write)
        with open(str(fifo_path), 'w') as fifo:
            fifo.write(action)
            fifo.flush()
        print(f"📡 Command '{action}' sent")
        return True
    except FileNotFoundError:
        print(f"❌ Control FIFO not found: {fifo_path}", file=sys.stderr)
        print("   Make sure Whisper GUI is running", file=sys.stderr)
        return False
    except Exception as e:
        print(f"❌ Error sending command: {e}", file=sys.stderr)
        return False


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    action = sys.argv[1].lower()

    # Check if GUI is running
    gui_pid = get_gui_pid()
    if not gui_pid:
        print("❌ Whisper GUI is not running (PID not found in ~/.whisper/app.lock)", file=sys.stderr)
        sys.exit(1)

    print(f"Found Whisper GUI (PID: {gui_pid})")

    if action == "status":
        print(f"GUI is running (PID: {gui_pid})")
        sys.exit(0)

    if action in ("toggle", "start", "stop"):
        if send_command(action):
            sys.exit(0)
        else:
            sys.exit(1)

    print(f"❌ Unknown action: {action}", file=sys.stderr)
    print("Valid actions: start, stop, toggle, status")
    sys.exit(1)


if __name__ == "__main__":
    main()
